{
  "manifest_version": 3,
  "name": "Task Scheduler",
  "version": "1.0.0",
  "description": "Schedule tasks, reminders, and URLs to open automatically",
  "permissions": [
    "storage",
    "notifications",
    "tabs",
    "alarms"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
